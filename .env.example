# Copy this file to `.env` in the workspace root before running the
# release commands. `.env` is intentionally gitignored.

CRAWLER4J_SPARKLE_FEED_URL='https://updates.example.com/mac/appcast.xml'
CRAWLER4J_SPARKLE_PUBLIC_ED_KEY='<sparkle-public-ed25519-key>'
# Choose one private key source for generate_appcast:
CRAWLER4J_SPARKLE_KEYCHAIN_ACCOUNT='ed25519'
# CRAWLER4J_SPARKLE_PRIVATE_ED_KEY_FILE='/absolute/path/to/sparkle-private-ed25519-key.txt'
# CRAWLER4J_SPARKLE_PRIVATE_ED_KEY='<sparkle-private-ed25519-key>'
# Public release root; deploy scripts append `/mac/` or `/win/`.
CRAWLER4J_UPDATE_UPLOAD_TARGET='deploy@example.internal:/var/www/crawler4j/'

# Windows PyInstaller onedir + Velopack release settings:
CRAWLER4J_VELOPACK_FEED_URL='https://updates.example.com/win/releases.win.json'
# CRAWLER4J_VELOPACK_PACK_ID='io.github.uroborus2s.crawler4j'
# CRAWLER4J_VELOPACK_CHANNEL='win'
# CRAWLER4J_VELOPACK_RUNTIME='win-x64'
# CRAWLER4J_VPK_BIN='vpk'
# Set to '1' to run `dnx vpk` instead of a globally installed `vpk`.
# CRAWLER4J_VPK_USE_DNX='0'
