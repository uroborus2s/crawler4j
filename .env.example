# Copy this file to `.env` in the workspace root before running the
# macOS internal release commands. `.env` is intentionally gitignored.

CRAWLER4J_SPARKLE_FEED_URL='https://updates.example.com/appcast.xml'
CRAWLER4J_SPARKLE_PUBLIC_ED_KEY='<sparkle-public-ed25519-key>'
CRAWLER4J_UPDATE_UPLOAD_TARGET='deploy@example.internal:/var/www/crawler4j/'
